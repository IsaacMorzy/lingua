---
import { buttonStyles } from '@/components/tailgrids/core/button';

export interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  primaryCta?: { href: string; label: string };
  secondaryCta?: { href: string; label: string };
  variant?: 'primary' | 'ink';
}

const {
  eyebrow,
  title,
  description,
  primaryCta = { href: '/admissions', label: 'Apply Now' },
  secondaryCta,
  variant = 'primary',
} = Astro.props;

const bg = variant === 'ink' ? 'bg-ink' : 'bg-primary';
const headingColor = 'text-white';
// On Vodafone red (#E60000), text-white/80 is ~5.0:1 (AA). text-slate-200 was ~3.3:1 (fail).
const bodyColor = 'text-white/85';
const eyebrowClass = 'bg-white/20';
const eyebrowText = 'text-white';
---

<section class:list={[bg, 'py-12 md:py-16']}>
  <div class="container-main text-center">
    {eyebrow && (
      <span class:list={['mb-4 inline-block rounded-full px-4 py-1 text-sm font-bold uppercase tracking-wider', eyebrowClass, eyebrowText]}>
        {eyebrow}
      </span>
    )}
    <h2 class:list={['text-3xl font-bold md:text-4xl', headingColor]}>{title}</h2>
    {description && (
      <p class:list={['mx-auto mt-4 max-w-2xl text-lg', bodyColor]}>{description}</p>
    )}
    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a href={primaryCta.href} class={buttonStyles({ variant: 'primary', appearance: 'fill', size: 'lg' })}>
        {primaryCta.label}
      </a>
      {secondaryCta && (
        <a href={secondaryCta.href} class={buttonStyles({ variant: 'primary', appearance: 'outline', size: 'lg' })}>
          {secondaryCta.label}
        </a>
      )}
    </div>
  </div>
</section>
