---
import { Badge } from '@/components/tailgrids/core/badge';
import { buttonStyles } from '@/styles/button';

export interface Props {
  title?: string;
  subtitle?: string;
  primaryCta?: { href: string; label: string };
  secondaryCta?: { href: string; label: string };
}

const {
  title = 'Education That Builds Futures',
  subtitle = 'IJLAPS is a TVETA-certified institution in Kenya offering languages, technology, business, and professional courses that prepare students for the modern workforce.',
  primaryCta = { href: '/admissions', label: 'Apply Now' },
  secondaryCta = { href: '/courses', label: 'Browse programmes' },
} = Astro.props;
---

<section class="bg-ink py-24 md:py-40">
  <div class="container-main">
    <div class="mx-auto max-w-4xl text-center">
      <Badge color="primary" size="md" className="mb-6 bg-white/10 text-white border-0">TVETA Certified Institution</Badge>
      <h1 class="text-5xl font-extrabold tracking-tight text-white sm:text-6xl md:text-7xl">
        {title}
      </h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-slate-300 md:text-xl">
        {subtitle}
      </p>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={primaryCta.href}
          class={buttonStyles({ variant: 'primary', size: 'lg' })}
        >
          {primaryCta.label}
        </a>
        <a
          href={secondaryCta.href}
          class={buttonStyles({ variant: 'primary', appearance: 'outline', size: 'lg' })}
        >
          {secondaryCta.label}
        </a>
      </div>
    </div>
  </div>
</section>
