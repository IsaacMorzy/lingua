---
import { buttonStyles } from '@/styles/button';
import { LANGUAGES, LANGUAGES_COUNT, PROGRAMS_COUNT, TECH_PROGRAMS, BUSINESS_PROGRAMS, TVETA_PROGRAMS, PROFESSIONAL_PROGRAMS, VOCATIONAL_PROGRAMS } from '@/lib/data';
import { Globe, Code, ChartBar, GraduationCap, Building, Wrench, MapPin, Mail, Phone, ArrowRight, Facebook, Twitter, Linkedin, Youtube } from '@/components/icons';

const currentYear = new Date().getFullYear();

const topLanguages = LANGUAGES.slice(0, 10);
const topTech = TECH_PROGRAMS.slice(0, 4);
const topBusiness = BUSINESS_PROGRAMS.slice(0, 4);
const topTveta = TVETA_PROGRAMS.slice(0, 4);
const topProfessional = [...PROFESSIONAL_PROGRAMS];
const topVocational = [...VOCATIONAL_PROGRAMS];
const programSummary = `${PROGRAMS_COUNT} programmes · ${LANGUAGES_COUNT} languages`;

const columns = [
  {
    title: 'About',
    links: [
      { label: 'Overview', href: '/about' },
      { label: 'Campus', href: '/campus' },
      { label: 'Mission & Values', href: '/mission-values' },
      { label: 'History', href: '/history' },
      { label: 'Leadership', href: '/leadership' },
    ],
  },
  {
    title: 'Admissions',
    links: [
      { label: 'Overview', href: '/admissions' },
      { label: 'How to Apply', href: '/how-to-apply' },
      { label: 'Tuition & Fees', href: '/tuition-fees' },
      { label: 'Financial Aid', href: '/financial-aid' },
      { label: 'Dates & Deadlines', href: '/dates-deadlines' },
    ],
  },
  {
    title: 'Academics',
    links: [
      { label: 'Overview', href: '/academics' },
      { label: 'Undergraduate', href: '/undergraduate' },
      { label: 'Graduate', href: '/graduate' },
      { label: 'Schools', href: '/schools' },
      { label: 'Online Education', href: '/online-education' },
      { label: 'Off-Campus Learning', href: '/off-campus-learning' },
      { label: 'Faculty', href: '/faculty' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Events', href: '/events' },
      { label: 'Instructors', href: '/instructors' },
      { label: 'Blog & News', href: '/blog' },
      { label: 'FAQ', href: '/faq' },
    ],
  },
];

const programGroups = [
  { title: 'Tech', icon: Code, programs: [...topTech.map((p) => ({ label: p.title, href: `/programs/tech/${p.slug}` })), { label: 'All Tech →', href: '/programs/tech', highlight: true }] },
  { title: 'Business', icon: ChartBar, programs: [...topBusiness.map((p) => ({ label: p.title, href: `/programs/business/${p.slug}` })), { label: 'All Business →', href: '/programs/business', highlight: true }] },
  { title: 'TVETA', icon: GraduationCap, programs: [...topTveta.map((p) => ({ label: p.title, href: `/programs/tveta/${p.slug}` })), { label: 'All TVETA →', href: '/programs/tveta', highlight: true }] },
  { title: 'Professional', icon: Building, programs: [...topProfessional.map((p) => ({ label: p.title, href: `/programs/professional/${p.slug}` })), { label: 'All Professional →', href: '/programs/professional', highlight: true }] },
  { title: 'Vocational', icon: Wrench, programs: [...topVocational.map((p) => ({ label: p.title, href: `/programs/vocational/${p.slug}` })), { label: 'All Vocational →', href: '/programs/vocational', highlight: true }] },
  { title: 'Languages', icon: Globe, programs: [...topLanguages.map((l) => ({ label: l.name, href: `/languages/${l.slug}` })), { label: 'All Languages →', href: '/languages', highlight: true }] },
];

const socialLinks = [
  { label: 'Facebook', href: 'https://facebook.com/ijlaps', Icon: Facebook },
  { label: 'Twitter', href: 'https://twitter.com/ijlaps', Icon: Twitter },
  { label: 'LinkedIn', href: 'https://linkedin.com/school/ijlaps', Icon: Linkedin },
  { label: 'YouTube', href: 'https://youtube.com/ijlaps', Icon: Youtube },
];
---

<footer class="bg-ink">
  <section class="border-b border-white/10">
    <div class="container-main py-10">
      <div class="grid gap-6 lg:grid-cols-2 lg:items-center">
        <div>
          <h2 class="text-2xl font-bold text-white md:text-3xl">Intake dates, bursaries, and programme news.</h2>
          <p class="mt-2 text-body-secondary">Sent before each intake window. No spam, unsubscribe any time.</p>
        </div>
        <form id="newsletter-form" class="flex flex-col gap-2 sm:flex-row" aria-label="Newsletter signup">
          <label for="newsletter-email" class="sr-only">Email address</label>
          <input
            id="newsletter-email"
            type="email"
            name="email"
            placeholder="you@example.com"
            required
            autocomplete="email"
            aria-describedby="newsletter-status"
            class="flex-1 rounded-lg border border-white/10 bg-ink-soft px-4 py-3 text-white placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary"
          />
          <button type="submit" class={buttonStyles({ variant: 'primary', appearance: 'fill', size: 'md' })}>
            Subscribe
          </button>
        </form>
        <div id="newsletter-status" class="mt-2 hidden text-sm" aria-live="polite"></div>
        <script>
          import { initNewsletterForm } from '@/scripts/newsletter';
          initNewsletterForm();
        </script>
      </div>
    </div>
  </section>

  <div class="container-main py-16">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-6">
      <div class="space-y-5 lg:col-span-2">
        <a href="/" class="flex items-center gap-2.5 text-xl font-extrabold text-white">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-primary text-sm font-black">I</span>
          IJLAPS
        </a>
        <p class="text-sm leading-relaxed text-body-secondary">
          TVETA-certified institution running {programSummary} across four schools. Nairobi campus with online and off-campus learning pathways nationwide.
        </p>
        <div class="flex items-center gap-2">
          {socialLinks.map((item) => (
            <a
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={item.label}
              class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-ink-soft text-muted transition-colors hover:bg-primary hover:text-white"
            >
              <item.Icon size={16} />
            </a>
          ))}
        </div>
        <address class="not-italic space-y-2 text-sm text-body-secondary">
          <p class="flex items-center gap-2"><MapPin size={14} /> IJLAPS House, Westlands, Nairobi</p>
          <p class="flex items-center gap-2"><Mail size={14} /> <a href="mailto:info@ijlaps.ac.ke" class="text-body-secondary hover:text-white transition-colors">info@ijlaps.ac.ke</a></p>
          <p class="flex items-center gap-2"><Phone size={14} /> <a href="tel:+254700000000" class="text-body-secondary hover:text-white transition-colors">+254 (0) 700 000 000</a></p>
        </address>
      </div>

      {columns.map((col) => (
        <div>
          <h3 class="mb-4 text-xs font-bold uppercase tracking-widest text-white">{col.title}</h3>
          <ul class="space-y-2 text-sm">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="text-body-secondary transition-colors hover:text-white">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <div class="md:col-span-2 lg:col-span-6">
        <h3 class="mb-4 text-xs font-bold uppercase tracking-widest text-white">Programmes & Languages</h3>
        <div class="grid grid-cols-2 gap-6 md:grid-cols-3 lg:grid-cols-6">
          {programGroups.map((group) => (
            <div>
              <h4 class="mb-3 flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-muted">
                <group.icon size={12} />
                {group.title}
              </h4>
              <ul class="space-y-1.5 text-xs">
                {group.programs.map((p) => (
                  <li>
                    <a
                      href={p.href}
                      class:list={[
                        'transition-colors',
                        p.highlight ? 'font-semibold text-primary hover:text-white' : 'text-body-secondary hover:text-white',
                      ]}
                    >
                      {p.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-main flex flex-col items-start justify-between gap-4 py-6 text-sm text-muted md:flex-row md:items-center">
      <p>&copy; {currentYear} IJLAPS. TVETA-registered institution, Nairobi, Kenya.</p>
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-xs">
        <a href="/contact" class="transition-colors hover:text-white">Contact</a>
        <a href="/faq" class="transition-colors hover:text-white">FAQ</a>
        <a href="/admissions" class="transition-colors hover:text-white">Apply</a>
        <span class="text-muted">TVETA Registered</span>
      </div>
    </div>
  </div>
</footer>
