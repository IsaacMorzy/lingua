---
import { buttonStyles } from '@/styles/button';
import { NAV_SECTIONS } from '@/lib/data';
import { ChevronDown, MenuIcon, X, Sun, Moon, ArrowRight, GraduationCap, Book, Building, Calendar, Mail, FileText, Globe } from '@/components/icons';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const sectionIcons: Record<string, any> = {
  'Academics': GraduationCap,
  'Languages': Globe,
  'Programs': Book,
  'About': Building,
  'Admissions': FileText,
  'Campus Life': Calendar,
  'Contact': Mail,
};

function isActive(href: string): boolean {
  const normalized = href.replace(/\/$/, '') || '/';
  return pathname === normalized || (normalized !== '/' && pathname.startsWith(normalized + '/'));
}

const sectionsWithActive = NAV_SECTIONS.map((section) => ({
  ...section,
  active: section.children.some((c) => c.href && isActive(c.href)),
}));
---

<header class="sticky top-0 z-50 border-b border-border bg-surface/95 backdrop-blur-sm">
  <div class="container-main flex h-16 items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2.5 text-xl font-extrabold text-body">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-primary text-sm text-white font-black">I</span>
      <span class="hidden sm:inline">IJLAPS</span>
    </a>

    <nav class="hidden items-center gap-0.5 lg:flex" aria-label="Primary">
      {sectionsWithActive.map((section) => {
        const Icon = sectionIcons[section.label];
        return (
          <div class="group/mega relative" data-megamenu>
            <button
              type="button"
              class:list={[
                'inline-flex items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-semibold transition-colors',
                section.active ? 'text-primary bg-primary-subtle' : 'text-body-secondary hover:text-primary hover:bg-primary-subtle/50',
              ]}
              aria-haspopup="true"
              aria-expanded="false"
              data-trigger
            >
              {Icon && <Icon size={16} />}
              {section.label}
              <ChevronDown size={14} className="transition-transform text-muted" />
            </button>

            <div
              data-panel
              class:list={[
                'absolute left-0 top-full mt-1.5 hidden rounded-xl border border-border bg-surface shadow-lg',
                section.wide ? 'w-[640px] p-5' : 'w-64 p-2',
              ]}
              role="menu"
            >
              {section.intro && (
                <p class="mb-3 border-b border-border pb-3 text-xs font-semibold uppercase tracking-wider text-muted">
                  {section.intro}
                </p>
              )}
              {section.wide ? (
                <div class="grid grid-cols-2 gap-x-4 gap-y-0.5">
                  {section.children.map((child) => {
                    const active = child.href && isActive(child.href);
                    const isAll = child.label === 'All Languages' || child.label === 'All Programs';
                    return child.href ? (
                      <a
                        href={child.href}
                        role="menuitem"
                        class:list={[
                          'flex items-start justify-between gap-3 rounded-lg px-3 py-2 text-sm transition-colors',
                          isAll ? 'font-semibold text-primary col-span-2 mb-1 border-b border-border pb-2' : 'text-body-secondary hover:bg-primary-subtle/50 hover:text-primary',
                          active && !isAll ? 'bg-primary-subtle text-primary font-semibold' : '',
                        ]}
                      >
                        <span class="flex items-start gap-2">
                          {active && !isAll && <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-primary" />}
                          {isAll ? (
                            <span class="flex items-center gap-2">
                              <ArrowRight size={14} />
                              {child.label}
                            </span>
                          ) : (
                            <span>
                              <span class="block font-medium">{child.label}</span>
                              {child.description && <span class="mt-0.5 block line-clamp-2 text-xs text-muted">{child.description}</span>}
                            </span>
                          )}
                        </span>
                        {child.meta && !isAll && (
                          <span class="flex-shrink-0 rounded bg-primary-subtle px-1.5 py-0.5 text-xs font-semibold text-primary">{child.meta}</span>
                        )}
                      </a>
                    ) : null;
                  })}
                </div>
              ) : (
                <div class="space-y-0.5">
                  {section.children.map((child) => {
                    const active = child.href && isActive(child.href);
                    return child.href ? (
                      <a
                        href={child.href}
                        role="menuitem"
                        class:list={[
                          'flex items-start justify-between gap-3 rounded-lg px-3 py-2 text-sm transition-colors',
                          active ? 'bg-primary-subtle text-primary font-semibold' : 'text-body-secondary hover:bg-primary-subtle/50 hover:text-primary',
                        ]}
                      >
                        <span class="flex items-start gap-2">
                          {active && <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-primary" />}
                          <span>
                            <span class="block font-medium">{child.label}</span>
                            {child.description && <span class="mt-0.5 block line-clamp-2 text-xs text-muted">{child.description}</span>}
                          </span>
                        </span>
                        <ArrowRight size={14} className="mt-1 text-muted opacity-0 -translate-x-1 transition-all group-hover/mega:opacity-100 group-hover/mega:translate-x-0" />
                      </a>
                    ) : null;
                  })}
                </div>
              )}
            </div>
          </div>
        );
      })}
    </nav>

    <div class="flex items-center gap-2">
      <button
        id="theme-toggle"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-body-secondary hover:bg-primary-subtle/50 transition-colors"
        aria-label="Toggle theme"
        aria-pressed="false"
        type="button"
      >
        <Sun id="theme-sun" size={18} class="hidden dark:block" />
        <Moon id="theme-moon" size={18} class="block dark:hidden" />
      </button>
      <a href="/admissions" class:list={[buttonStyles({ size: 'sm' }), 'hidden lg:inline-flex']}>
        Apply Now
      </a>
      <button
        id="menu-toggle"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-body-secondary hover:bg-primary-subtle/50 transition-colors lg:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <MenuIcon id="menu-open-icon" size={20} />
        <X id="menu-close-icon" size={20} class="hidden" />
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-border bg-surface lg:hidden">
    <div class="container-main max-h-[calc(100vh-4rem)] overflow-y-auto py-4">
      <a
        href="/"
        class:list={[
          'flex items-center gap-2 rounded-lg px-3 py-2.5 text-sm font-semibold transition-colors',
          pathname === '/' ? 'text-primary bg-primary-subtle' : 'text-body-secondary hover:bg-primary-subtle/50 hover:text-primary',
        ]}
      >
        <Building size={16} />
        Home
      </a>

      {sectionsWithActive.map((section) => {
        const SectionIcon = sectionIcons[section.label] || Building;
        return (
          <details class="group/mob mt-1 [&_summary::-webkit-details-marker]:hidden">
            <summary class:list={[
              'flex cursor-pointer items-center justify-between rounded-lg px-3 py-2.5 text-sm font-semibold transition-colors',
              section.active ? 'text-primary' : 'text-body-secondary hover:bg-primary-subtle/50 hover:text-primary',
            ]}>
              <span class="flex items-center gap-2">
                <SectionIcon size={16} />
                {section.label}
              </span>
              <ChevronDown size={14} className="transition-transform group-open/mob:rotate-180 text-muted" />
            </summary>
            <div class="mt-1 ml-4 space-y-0.5 border-l-2 border-primary/20 pl-3">
              {section.children.map((child) => {
                const active = child.href && isActive(child.href);
                return child.href && (
                  <a
                    href={child.href}
                    class:list={[
                      'flex items-center gap-2 rounded-lg px-3 py-2 text-sm transition-colors',
                      active ? 'text-primary font-semibold bg-primary-subtle' : 'text-body-secondary hover:bg-primary-subtle/50 hover:text-primary',
                    ]}
                  >
                    {active && <span class="h-1.5 w-1.5 rounded-full bg-primary" />}
                    {child.label}
                  </a>
                );
              })}
            </div>
          </details>
        );
      })}

      <a href="/admissions" class:list={[buttonStyles({ size: 'sm' }), 'mt-4 w-full']}>Apply Now</a>
    </div>
  </div>
</header>

<script type="module">
  (function () {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const openI = document.getElementById('menu-open-icon');
    const closeI = document.getElementById('menu-close-icon');
    if (!toggle || !menu || !openI || !closeI) return;

    function setOpen(open) {
      if (open) {
        menu.classList.remove('hidden');
        openI.classList.add('hidden');
        closeI.classList.remove('hidden');
        toggle.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      } else {
        menu.classList.add('hidden');
        openI.classList.remove('hidden');
        closeI.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
    }

    toggle.addEventListener('click', () => setOpen(menu.classList.contains('hidden')));
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.classList.contains('hidden')) setOpen(false);
    });

    document.querySelectorAll('[data-megamenu]').forEach((menuEl) => {
      const trig = menuEl.querySelector('[data-trigger]');
      const panel = menuEl.querySelector('[data-panel]');
      if (!trig || !panel) return;

      trig.addEventListener('click', (e) => {
        e.preventDefault();
        const expanded = trig.getAttribute('aria-expanded') === 'true';
        document.querySelectorAll('[data-megamenu] [data-trigger]').forEach((t) => t.setAttribute('aria-expanded', 'false'));
        document.querySelectorAll('[data-megamenu] [data-panel]').forEach((p) => p.classList.add('hidden'));
        if (expanded) {
          trig.setAttribute('aria-expanded', 'false');
          panel.classList.add('hidden');
        } else {
          trig.setAttribute('aria-expanded', 'true');
          panel.classList.remove('hidden');
          panel.classList.add('block');
        }
      });

      document.addEventListener('click', (e) => {
        if (!menuEl.contains(e.target)) {
          trig.setAttribute('aria-expanded', 'false');
          panel.classList.add('hidden');
        }
      });

      trig.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          trig.setAttribute('aria-expanded', 'false');
          panel.classList.add('hidden');
          trig.focus();
        }
      });
    });
  })();

  (function () {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    function setTheme(dark) {
      if (dark) {
        document.documentElement.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      } else {
        document.documentElement.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      }
    }
    btn.addEventListener('click', () => setTheme(!document.documentElement.classList.contains('dark')));
  })();
</script>
