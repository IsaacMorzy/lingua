---
import { buttonStyles } from '@/components/tailgrids/core/button';
import { NAV_SECTIONS } from '@/lib/data';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

interface SectionContext {
  label: string;
  href?: string;
}

function activeSection(
  children: { label: string; href?: string }[]
): SectionContext | undefined {
  for (const child of children) {
    if (!child.href) continue;
    const normalized = child.href.replace(/\/$/, '') || '/';
    if (pathname === normalized) return { label: child.label, href: child.href };
    if (pathname.startsWith(normalized + '/')) return { label: child.label, href: child.href };
  }
  return undefined;
}

// Pre-compute which (if any) section is currently the active one
const sectionsWithActive = NAV_SECTIONS.map((section) => ({
  ...section,
  activeChild: activeSection(section.children),
}));
---

<header class="sticky top-0 z-50 border-b border-border bg-surface">
  <div class="container-main flex h-16 items-center justify-between gap-6">
    <a href="/" class="flex items-center gap-2 text-xl font-extrabold text-body">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded bg-primary text-white font-black">I</span>
      <span class="hidden sm:inline">IJLAPS</span>
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary navigation">
      {sectionsWithActive.map((section) => (
        <div class="group relative" data-megamenu>
          <button
            type="button"
            class:list={[
              'inline-flex items-center gap-1 rounded-md px-3 py-2 text-sm font-semibold transition-colors',
              section.activeChild ? 'text-primary' : 'text-body-secondary hover:text-primary',
            ]}
            aria-haspopup="true"
            aria-expanded="false"
            data-trigger
          >
            {section.label}
            <svg class="h-3.5 w-3.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <div
            data-panel
            class:list={[
              section.wide
                ? 'absolute left-0 top-full mt-1 hidden rounded-xl border border-border bg-surface shadow-xl group-hover:block group-focus-within:block p-4'
                : 'absolute left-0 top-full mt-1 hidden min-w-[260px] rounded-xl border border-border bg-surface shadow-xl group-hover:block group-focus-within:block',
            ]}
            role="menu"
          >
            {section.wide ? (
              <div class="grid grid-cols-3 gap-2 min-w-[540px]">
                {section.children.map((child) => {
                  const isActive = child.href && (pathname === child.href.replace(/\/$/, '') || pathname === '/') && child.href === section.activeChild?.href;
                  return child.href ? (
                    <a
                      href={child.href}
                      role="menuitem"
                      class:list={[
                        'rounded-lg px-3 py-2 text-sm transition-colors hover:bg-primary-subtle',
                        isActive ? 'text-primary font-semibold' : 'text-body-secondary hover:text-primary',
                      ]}
                    >
                      {child.label}
                    </a>
                  ) : null;
                })}
              </div>
            ) : (
              <ul class="py-2">
                {section.children.map((child) => {
                  const isActive = child.href && (pathname === child.href.replace(/\/$/, '') || pathname === '/') && child.href === section.activeChild?.href;
                  return (
                    <li>
                      {child.href ? (
                        <a
                          href={child.href}
                          role="menuitem"
                          class:list={[
                            'flex items-center justify-between px-4 py-2 text-sm transition-colors hover:bg-primary-subtle',
                            isActive ? 'text-primary font-semibold' : 'text-body-secondary hover:text-primary',
                          ]}
                        >
                          {child.label}
                          <svg class="h-3.5 w-3.5 text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                          </svg>
                        </a>
                      ) : null}
                    </li>
                  );
                })}
              </ul>
            )}
          </div>
        </div>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <button
        id="theme-toggle"
        class="inline-flex items-center justify-center rounded-md p-2 text-body-secondary hover:bg-slate-100 dark:hover:bg-ink-soft transition-colors"
        aria-label="Toggle theme"
        title="Toggle dark mode"
        type="button"
      >
        <svg id="theme-sun" class="hidden h-5 w-5 dark:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg id="theme-moon" class="block h-5 w-5 dark:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
      <a href="/admissions" class:list={[buttonStyles({ size: 'sm' }), 'hidden lg:inline-flex']}>
        Apply Now
      </a>
      <button
        id="menu-toggle"
        class="inline-flex items-center justify-center rounded-md p-2 text-body-secondary hover:bg-slate-100 dark:hover:bg-ink-soft transition-colors lg:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-open-icon" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-close-icon" class="hidden h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
<div
  id="mobile-menu"
  class="hidden border-t border-border bg-surface lg:hidden"
  >
    <div class="container-main max-h-[calc(100vh-4rem)] overflow-y-auto py-4">
      <a
        href="/"
        class:list={[
          'block rounded-md px-3 py-2 text-sm font-semibold transition-colors',
          pathname === '/' ? 'text-primary bg-primary-subtle' : 'text-body-secondary hover:bg-slate-100 dark:hover:bg-ink-soft hover:text-primary',
        ]}
      >Home</a>

      {sectionsWithActive.map((section) => (
        <details class="group/section [&_summary::-webkit-details-marker]:hidden">
          <summary class:list={[
            'flex cursor-pointer items-center justify-between rounded-md px-3 py-2 text-sm font-semibold transition-colors',
            section.activeChild ? 'text-primary' : 'text-body-secondary hover:bg-slate-100 dark:hover:bg-ink-soft hover:text-primary',
          ]}>
            {section.label}
            <svg class="h-3.5 w-3.5 transition-transform group-open/section:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <ul class="mt-1 mb-2 ml-3 border-l border-border pl-2 space-y-1">
            {section.children.map((child) => child.href && (
              <li>
                <a
                  href={child.href}
                  class:list={[
                    'flex items-center justify-between rounded px-2 py-2 text-sm transition-colors hover:bg-slate-100 dark:hover:bg-ink-soft',
                    pathname === child.href.replace(/\/$/, '') || pathname === '/' && child.href === section.activeChild?.href ? 'text-primary font-semibold' : 'text-body-secondary hover:text-primary',
                  ]}
                >
                  {child.label}
                  <svg class="h-3 w-3 text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </details>
      ))}

      <a href="/admissions" class:list={[buttonStyles({ size: 'sm' }), 'mt-4 w-full']}>Apply Now</a>
    </div>
  </div>
</header>

<script type="module">
  (function () {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const openI = document.getElementById('menu-open-icon');
    const closeI = document.getElementById('menu-close-icon');
    if (!toggle || !menu || !openI || !closeI) return;

    function setOpen(open) {
      if (open) {
        menu.classList.remove('hidden');
        openI.classList.add('hidden');
        closeI.classList.remove('hidden');
        toggle.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      } else {
        menu.classList.add('hidden');
        openI.classList.remove('hidden');
        closeI.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
    }

    toggle.addEventListener('click', () => {
      setOpen(menu.classList.contains('hidden'));
    });

    menu.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.classList.contains('hidden')) setOpen(false);
    });

    // Desktop: click-trigger support for keyboard users (touch devices fall back to this too)
    document.querySelectorAll('[data-megamenu]').forEach((menu) => {
      const trig = menu.querySelector('[data-trigger]');
      const panel = menu.querySelector('[data-panel]');
      if (!trig || !panel) return;

      trig.addEventListener('click', (e) => {
        e.preventDefault();
        const expanded = trig.getAttribute('aria-expanded') === 'true';
        // close all other panels
        document.querySelectorAll('[data-megamenu] [data-trigger]').forEach((t) => t.setAttribute('aria-expanded', 'false'));
        document.querySelectorAll('[data-megamenu] [data-panel]').forEach((p) => {
          if (p !== panel) p.classList.add('hidden');
        });
        if (expanded) {
          trig.setAttribute('aria-expanded', 'false');
          panel.classList.add('hidden');
        } else {
          trig.setAttribute('aria-expanded', 'true');
          panel.classList.remove('hidden');
          panel.classList.add('block');
        }
      });

      // close on outside click
      document.addEventListener('click', (e) => {
        const target = e.target;
        if (!menu.contains(target)) {
          trig.setAttribute('aria-expanded', 'false');
          panel.classList.add('hidden');
        }
      });

      // Esc closes
      trig.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          trig.setAttribute('aria-expanded', 'false');
          panel.classList.add('hidden');
          trig.focus();
        }
      });
    });
  })();

  // Theme toggle
  (function () {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;

    function setTheme(dark) {
      if (dark) {
        document.documentElement.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      } else {
        document.documentElement.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      }
    }

    btn.addEventListener('click', () => {
      setTheme(!document.documentElement.classList.contains('dark'));
    });
  })();
</script>
