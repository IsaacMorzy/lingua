---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  keywords?: string[];
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'IJLAPS, TVETA-Certified Languages, Technology & Business',
  description = 'IJLAPS is a TVETA-certified institution in Kenya offering languages, technology bootcamps, business, and vocational training. Apply now.',
  canonicalPath = Astro.url.pathname,
  keywords = ['IJLAPS', 'TVETA', 'Kenya education', 'language school', 'tech bootcamp'],
  ogImage = 'https://ijlaps.ac.ke/assets/lingua/frontend/og-image.png',
  noindex = false,
  jsonLd,
} = Astro.props;

const siteUrl = 'https://ijlaps.ac.ke';
const normalizedPath = canonicalPath === '/' ? '' : canonicalPath.replace(/\/$/, '');
const canonicalUrl = `${siteUrl}${normalizedPath}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const jsonLdArray = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];

// Default organization JSON-LD (added on every page for brand SEO)
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'International Joint Languages and Professional Studies',
  alternateName: 'IJLAPS',
  url: siteUrl,
  logo: `${siteUrl}/assets/lingua/frontend/favicon.svg`,
  description: 'TVETA-certified institution in Kenya offering languages, technology, business, and vocational training.',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Nairobi',
    addressCountry: 'KE',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+254700000000',
    contactType: 'admissions',
    email: 'admissions@ijlaps.ac.ke',
  },
};

const allJsonLd = [orgJsonLd, ...jsonLdArray.map((j) => JSON.parse(JSON.stringify(j)))];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(', ')} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="IJLAPS" />
    <meta property="og:locale" content="en_KE" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" href="/assets/lingua/frontend/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    {allJsonLd.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-white focus:shadow-lg">Skip to main content</a>
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
