---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTABand from '../components/CTABand.astro';
import { Link } from '@/components/tailgrids/core/link';
import { Badge } from '@/components/tailgrids/core/badge';
import { Card, CardHeader, CardTitle, CardContent, CardFooter } from '@/components/tailgrids/core/card';
import { Book, Code, ChartBar, GraduationCap, Trophy, Target, Sparkles, Monitor, Globe, ArrowRight } from '@/components/icons';

const schools = [
  {
    id: 'languages',
    title: 'School of Languages',
    href: '/schools#languages',
    blurb: '10 languages, CEFR-aligned, with internationally-recognised exam preparation.',
    programs: 'A1 → C2 across English, French, Arabic, Chinese, German, Kiswahili, Spanish, Japanese, Portuguese, Italian.',
    icon: Book,
  },
  {
    id: 'technology',
    title: 'School of Technology',
    href: '/schools#technology',
    blurb: 'Tech bootcamps and an ICT diploma, all aimed at career-launching outcomes.',
    programs: 'Software Engineering, Data Science, Cybersecurity, AWS DevOps, Applied AI, plus short courses.',
    icon: Code,
  },
  {
    id: 'business',
    title: 'School of Business',
    href: '/schools#business',
    blurb: 'Practice-led programmes in management, marketing, analytics, and entrepreneurship.',
    programs: 'Business Management, Digital Marketing, Business Analytics, Entrepreneurship, Project Management, Procurement, HR.',
    icon: ChartBar,
  },
  {
    id: 'tveta',
    title: 'TVETA Programmes',
    href: '/schools#tveta',
    blurb: 'Competency-based trades and technical certifications recognised by TVETA.',
    programs: 'Electrical Installation, Plumbing, Welding, Graphic Design, ICT Diploma, and more.',
    icon: GraduationCap,
  },
];

const outcomes = [
  { value: '94%', label: 'First-sitting exam pass-rate (B2+ languages)' },
  { value: '78%', label: 'Tech bootcamp placement within 6 months' },
  { value: '85%', label: 'TVETA artisan placement' },
  { value: '92%', label: 'Completion rate across all programmes' },
];

const atAGlance = [
  { value: '4', label: 'Schools' },
  { value: '10', label: 'Languages taught' },
  { value: '14', label: 'Tech programmes' },
  { value: '7', label: 'Business programmes' },
  { value: '5', label: 'TVETA certifications' },
];
---

<Layout
  title="Academics | IJLAPS"
  description="IJLAPS academic portfolio: 4 schools covering 10 languages, tech bootcamps, business programmes, and TVETA trades. CEFR, AWS, TVETA, IPC and other industry certifications."
  canonicalPath="/academics"
  keywords={['IJLAPS academics', 'IJLAPS schools', 'language school Nairobi', 'tech bootcamp Nairobi', 'TVETA programmes']}
>
  <Breadcrumbs crumbs={[{ label: 'Home', href: '/' }, { label: 'Academics' }]} />

  <PageHero
    variant="decorative"
    eyebrow="Academics"
    title="A four-school academic structure."
    subtitle="IJLAPS is organised into four schools, Languages, Technology, Business, and TVETA trades, that share a single academic quality framework and a single student services team."
  />

  <section class="section bg-surface"><div class="container-main">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <Badge color="primary" size="md" className="mb-4">Our Schools</Badge>
        <h2 class="text-3xl font-bold text-body md:text-4xl">Four schools, one mission</h2>
        <div class="divider-accent mt-4" />
        <p class="mt-4 text-lg text-body-secondary">Each school brings its own expertise, sharing a single academic-quality framework.</p>
      </div>

      <div class="grid gap-8 md:grid-cols-2">
        {schools.map((s) => {
          const Icon = s.icon;
          return (
            <article id={s.id} class="rounded-2xl border-2 border-transparent bg-surface p-8 shadow-sm transition-shadow hover:border-primary/20 hover:shadow-md">
              <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary-subtle text-primary">
                <Icon size={24} />
              </div>
              <h2 class="text-2xl font-bold text-body">{s.title}</h2>
              <p class="mt-3 text-body-secondary">{s.blurb}</p>
              <div class="mt-4 rounded-lg bg-canvas p-4 text-sm text-body-secondary">
                <strong class="block text-body">Programmes</strong>
                {s.programs}
              </div>
              <Link variant="primary" size="sm" className="mt-4" href={s.href}>
                Visit {s.title}
                <ArrowRight size={16} />
              </Link>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section bg-primary-subtle"><div class="container-main">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <Badge color="primary" size="md" className="mb-4">Outcomes</Badge>
        <h2 class="text-3xl font-bold text-body md:text-4xl">Quality outcomes, school by school</h2>
        <div class="divider-accent mt-4" />
        <p class="mt-4 text-lg text-body-secondary">
          We publish yearly figures on learner outcomes across all our programmes. Numbers are reviewed by an
          independent academic-quality panel and updated after each cohort close-out.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {outcomes.map((o) => (
          <div class="rounded-xl border-2 border-transparent bg-surface p-6 text-center shadow-sm transition-shadow hover:border-primary/20 hover:shadow-md">
            <Trophy size={32} className="mx-auto mb-2 text-primary/60" />
            <div class="text-4xl font-extrabold text-primary">{o.value}</div>
            <div class="mt-2 text-sm font-medium text-body-secondary">{o.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-canvas"><div class="container-main">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <Badge color="primary" size="md" className="mb-4">At a glance</Badge>
        <h2 class="text-3xl font-bold text-body md:text-4xl">Programmes at a glance</h2>
        <div class="divider-accent mt-4" />
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
        {atAGlance.map((a) => (
          <div class="rounded-xl border-2 border-transparent bg-surface p-6 text-center shadow-sm transition-shadow hover:border-primary/20 hover:shadow-md">
            <Target size={24} className="mx-auto mb-1 text-primary/60" />
            <div class="text-3xl font-extrabold text-primary">{a.value}</div>
            <div class="mt-1 text-sm font-medium text-body-secondary">{a.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-surface"><div class="container-main">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <Badge color="primary" size="md" className="mb-4">Modes of study</Badge>
        <h2 class="text-3xl font-bold text-body md:text-4xl">How learners study at IJLAPS</h2>
        <div class="divider-accent mt-4" />
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        <Card className="border-2 border-transparent shadow-sm transition-shadow hover:border-primary/20 hover:shadow-md">
          <CardHeader>
            <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-primary-subtle text-primary">
              <Monitor size={20} />
            </div>
            <CardTitle>On campus</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-body-secondary">Full-time intensive study at our Westlands campus with labs, library, and student support services.</p>
          </CardContent>
          <CardFooter>
            <Link variant="primary" size="sm" href="/campus">See our campus <ArrowRight size={16} /></Link>
          </CardFooter>
        </Card>
        <Card className="border-2 border-transparent shadow-sm transition-shadow hover:border-primary/20 hover:shadow-md">
          <CardHeader>
            <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-primary-subtle text-primary">
              <Globe size={20} />
            </div>
            <CardTitle>Online</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-body-secondary">Live cohorts and recorded programmes taught by the same IJLAPS faculty, optimised for remote study.</p>
          </CardContent>
          <CardFooter>
            <Link variant="primary" size="sm" href="/online-education">Online education <ArrowRight size={16} /></Link>
          </CardFooter>
        </Card>
        <Card className="border-2 border-transparent shadow-sm transition-shadow hover:border-primary/20 hover:shadow-md">
          <CardHeader>
            <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-primary-subtle text-primary">
              <Sparkles size={20} />
            </div>
            <CardTitle>Off-campus</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-body-secondary">Satellite study centres across Kenya and partner-workplace apprenticeship programmes.</p>
          </CardContent>
          <CardFooter>
            <Link variant="primary" size="sm" href="/off-campus-learning">Off-campus learning <ArrowRight size={16} /></Link>
          </CardFooter>
        </Card>
      </div>
    </div>
  </section>

  <CTABand
    title="Find your programme"
    description="Pick a school, browse programmes, or talk to admissions."
    primaryCta={{ href: '/schools', label: 'Browse schools' }}
    secondaryCta={{ href: '/admissions', label: 'Apply now' }}
  />
</Layout>
