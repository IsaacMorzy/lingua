---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { Breadcrumbs } from '@/components/tailgrids/core/breadcrumbs';
import { Avatar, AvatarImage, AvatarFallback } from '@/components/tailgrids/core/avatar';
import { Badge } from '@/components/tailgrids/core/badge';
import { Card, CardHeader, CardTitle, CardContent, CardFooter } from '@/components/tailgrids/core/card';
import { buttonStyles } from '@/styles/button';
import { Users, GraduationCap, Star } from '@/components/icons';

// TODO: Replace ui-avatars placeholder images with real instructor photos from Frappe or local assets.
interface Instructor {
  name: string;
  role: string;
  bio: string;
  photo: string;
  subjects: string[];
}

const instructors: Instructor[] = [
  {
    name: 'Dr. Jane Mwangi',
    role: 'Head of Languages',
    bio: 'Applied linguist. 15 years teaching English, French, and Arabic. PhD from Moi University.',
    photo: 'https://ui-avatars.com/api/?name=Jane+Mwangi&background=1e40af&color=fff&size=256',
    subjects: ['English', 'French', 'Arabic'],
  },
  {
    name: 'James Otieno',
    role: 'Lead ICT Instructor',
    bio: 'Software engineer and educator. Former lead at two Nairobi tech firms.',
    photo: 'https://ui-avatars.com/api/?name=James+Otieno&background=047857&color=fff&size=256',
    subjects: ['ICT', 'Software Development'],
  },
  {
    name: 'Grace Wanjiku',
    role: 'Business Studies Coordinator',
    bio: 'MBA Strathmore. Ten years in entrepreneurship training and marketing education.',
    photo: 'https://ui-avatars.com/api/?name=Grace+Wanjiku&background=b45309&color=fff&size=256',
    subjects: ['Business', 'Marketing'],
  },
  {
    name: 'Michael Kipchirchir',
    role: 'TVETA Programs Lead',
    bio: 'TVETA-certified trainer. Fifteen years in vocational and technical education across Kenya.',
    photo: 'https://ui-avatars.com/api/?name=Michael+Kipchirchir&background=0369a1&color=fff&size=256',
    subjects: ['TVETA', 'Technical Skills'],
  },
  {
    name: 'Amina Hassan',
    role: 'French & Swahili Instructor',
    bio: 'Native French speaker. Eight years teaching French and Swahili through immersion methods.',
    photo: 'https://ui-avatars.com/api/?name=Amina+Hassan&background=1e40af&color=fff&size=256',
    subjects: ['French', 'Swahili'],
  },
  {
    name: 'David Kimani',
    role: 'Digital Skills Instructor',
    bio: 'Digital marketer and designer. Runs a Nairobi-based studio alongside teaching at IJLAPS.',
    photo: 'https://ui-avatars.com/api/?name=David+Kimani&background=047857&color=fff&size=256',
    subjects: ['Digital Marketing', 'Design'],
  },
];
---

<Layout title="Instructors | IJLAPS" description="Meet the instructors at IJLAPS." canonicalPath="/instructors">
  <Breadcrumbs items={[{ href: '/', label: 'Home' }, { href: '', label: 'Instructors' }]} dividerType="chevron" />

  <PageHero
    variant="decorative"
    eyebrow="Instructors"
    title="Faculty directory"
    subtitle="Practising language teachers, software engineers, and business trainers who teach what they do."
  />

  <section class="section bg-canvas"><div class="container-main">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          instructors.map((instructor) => (
            <article>
              <Card className="rounded-xl border-2 border-transparent p-6 text-center shadow-sm transition-shadow hover:border-primary/20 hover:shadow-md h-full">
                <CardHeader>
                  <Avatar size="xxl" className="mx-auto mb-4 border-4 border-white shadow-md">
                    <AvatarImage
                      src={instructor.photo}
                      alt={`Representational photo for ${instructor.name}, ${instructor.role}`}
                    />
                    <AvatarFallback>{instructor.name.split(' ').map(n => n[0]).join('')}</AvatarFallback>
                  </Avatar>
                  <h2 class="text-xl font-semibold text-body">{instructor.name}</h2>
                  <p class="text-sm font-semibold text-primary">{instructor.role}</p>
                </CardHeader>
                <CardContent>
                  <p class="text-body-secondary">{instructor.bio}</p>
                </CardContent>
                <CardFooter>
                  <div class="mt-2 flex flex-wrap justify-center gap-2">
                    {instructor.subjects.map((subject) => (
                      <Badge key={subject} color="neutral" size="sm">
                        {subject}
                      </Badge>
                    ))}
                  </div>
                </CardFooter>
              </Card>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section bg-primary"><div class="container-main text-center">
      <h2 class="text-3xl font-bold text-white md:text-4xl">Join our faculty</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-white/85">
        We hire practising language teachers, engineers, and tradespeople. Send a CV and cover note.
      </p>
      <div class="mt-8">
        <a href="/contact" class={buttonStyles({ variant: 'primary', appearance: 'outline', size: 'lg' })}>
          Get in Touch
        </a>
      </div>
    </div>
  </section>
</Layout>
