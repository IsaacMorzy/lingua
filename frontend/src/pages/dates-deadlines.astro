---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CTABand from '../components/CTABand.astro';
import { Breadcrumbs } from '@/components/tailgrids/core/breadcrumbs';
import { TableRoot, TableHeader, TableBody, TableHead, TableRow, TableCell } from '@/components/tailgrids/core/table';
import { Badge } from '@/components/tailgrids/core/badge';
import { Alert, AlertIndicator, AlertContent, AlertTitle, AlertDescription } from '@/components/tailgrids/core/alert';
import { Card, CardHeader, CardTitle, CardContent, CardFooter } from '@/components/tailgrids/core/card';

const intakes = [
  { month: 'January', label: 'Main Intake', window: 'Cohort opens 13 Jan 2026', languages: 'A1, A2, B1, B2 cohorts' },
  { month: 'May', label: 'Mid-year Intake', window: 'Cohort opens 11 May 2026', languages: 'A1, A2, B1 cohorts' },
  { month: 'September', label: 'September Intake', window: 'Cohort opens 14 Sep 2026', languages: 'B1, B2, C1, C2 cohorts' },
];

const examDates = [
  {
    exam: 'IELTS Academic',
    body: 'British Council & IDP Nairobi',
    dates: ['8 Feb 2026', '23 Aug 2026', '22 Nov 2026'],
    registerBy: '25 days before',
  },
  {
    exam: 'DELF B2 / DALF C1',
    body: 'Alliance Française Nairobi',
    dates: ['6 Jun 2026', '14 Nov 2026'],
    registerBy: '6 weeks before',
  },
  {
    exam: 'Cambridge B2 First',
    body: 'British Council Nairobi',
    dates: ['17 May 2026', '6 Dec 2026'],
    registerBy: '8 weeks before',
  },
  {
    exam: 'HSK Sitting 1–3',
    body: 'Confucius Institute Nairobi',
    dates: ['21 Mar 2026', '13 Jun 2026', '15 Nov 2026'],
    registerBy: '4 weeks before',
  },
  {
    exam: 'ALPT',
    body: 'Arabic Language Testing Centre',
    dates: ['11 Apr 2026', '10 Oct 2026'],
    registerBy: '4 weeks before',
  },
  {
    exam: 'JLPT N5–N4',
    body: 'Japan Foundation Nairobi (annual)',
    dates: ['14 Jun 2026', '7 Dec 2026'],
    registerBy: 'May 2026 / Nov 2026',
  },
];

const keyDeadlines = [
  { date: '15 Dec 2025', stage: 'January intake applications close' },
  { date: '20 Mar 2026', stage: 'May intake applications close' },
  { date: '15 Jul 2026', stage: 'September intake applications close' },
  { date: '30 days before start', stage: 'Bursary / Financial-aid window closes' },
  { date: '14 days before start', stage: 'Late-application waitlist closed' },
];

const techCohorts = [
  { programme: 'Full Stack Software Engineering', next: '20 Jan 2026', mode: 'Full-time Hybrid' },
  { programme: 'Data Science Bootcamp', next: '17 Feb 2026', mode: 'Full-time Hybrid' },
  { programme: 'Cybersecurity Bootcamp', next: '10 Mar 2026', mode: 'Full-time Hybrid' },
  { programme: 'AWS DevOps Engineering', next: '21 Apr 2026', mode: 'Full-time Hybrid' },
];
---

<Layout
  title="Dates & Deadlines | IJLAPS"
  description="Academic calendar with intake dates, exam sitting dates, registration deadlines, and key admissions milestones for every IJLAPS programme."
  canonicalPath="/dates-deadlines"
  keywords={['IJLAPS intake dates', 'IELTS dates Kenya', 'DELF DALF dates Nairobi', 'academic calendar IJLAPS']}
>
  <Breadcrumbs items={[{ href: '/', label: 'Home' }, { href: '/admissions', label: 'Admissions' }, { href: '', label: 'Dates & Deadlines' }]} dividerType="chevron" />

  <PageHero
    eyebrow="Admissions"
    title="Plan your application around these dates."
    subtitle="Three calendar intakes a year, ten exam-board sittings we routinely register students for, and a few deadlines that surprise people if they miss them."
  />

  <section class="bg-surface border-b border-border py-6">
    <div class="container-main space-y-3">
      <Alert status="warning">
        <AlertIndicator />
        <AlertContent>
          <AlertTitle>Late applications queue for the next intake.</AlertTitle>
          <AlertDescription>
            IJLAPS does not run continuous rolling admissions. Submitting more than 14 days before the cohort start is recommended, late applications move to the next intake.
          </AlertDescription>
        </AlertContent>
      </Alert>
    </div>
  </section>

  <section class="section bg-surface">
    <div class="container-main">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <Badge color="primary" size="md" className="mb-4">Intakes</Badge>
        <h2 class="text-3xl font-bold text-body md:text-4xl">Three intakes per year</h2>
        <p class="mt-4 text-lg text-body-secondary">
          Most programmes begin in January, May, or September. Bootcamps and short courses may run additional
          cohorts, see the programme page for specifics.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {intakes.map((i) => (
          <Card className="shadow-sm">
            <CardHeader>
              <Badge color="primary" size="sm">{i.month}</Badge>
              <CardTitle className="mt-3">{i.label}</CardTitle>
            </CardHeader>
            <CardContent>
              <p class="text-sm text-body-secondary">{i.window}</p>
              <div class="mt-4 rounded-lg bg-canvas p-3 text-xs text-body-secondary">
                <strong class="block text-body">Languages opening:</strong>
                {i.languages}
              </div>
            </CardContent>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-canvas">
    <div class="container-main">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <Badge color="primary" size="md" className="mb-4">Exams</Badge>
        <h2 class="text-3xl font-bold text-body md:text-4xl">Exam sitting dates we register for</h2>
        <p class="mt-4 text-lg text-body-secondary">
          IJLAPS handles registration for the sitting dates below. Exam fees are paid directly to the examining body.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {examDates.map((e) => (
          <Card className="shadow-sm">
            <CardHeader>
              <CardTitle>{e.exam}</CardTitle>
              <p class="mt-1 text-xs uppercase tracking-wider text-body-secondary">{e.body}</p>
            </CardHeader>
            <CardContent>
              <ul class="mt-4 space-y-2 text-sm text-body-secondary">
                {e.dates.map((d) => (
                  <li class="flex items-center gap-2">
                    <span class="inline-flex h-2 w-2 rounded-full bg-secondary"></span>
                    {d}
                  </li>
                ))}
              </ul>
            </CardContent>
            <CardFooter>
              <p class="text-xs text-body-secondary">Register by: <strong>{e.registerBy}</strong></p>
            </CardFooter>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-surface">
    <div class="container-main">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <Badge color="primary" size="md" className="mb-4">Technology programmes</Badge>
        <h2 class="text-3xl font-bold text-body md:text-4xl">Next tech bootcamp cohorts</h2>
      </div>

      <TableRoot>
        <TableHeader>
          <TableRow>
            <TableHead>Programme</TableHead>
            <TableHead>Mode</TableHead>
            <TableHead className="text-right">Next cohort</TableHead>
          </TableRow>
        </TableHeader>
        <TableBody>
          {techCohorts.map((row) => (
            <TableRow>
              <TableCell className="font-bold text-body">{row.programme}</TableCell>
              <TableCell className="text-sm text-body-secondary">{row.mode}</TableCell>
              <TableCell className="text-right font-bold text-primary">{row.next}</TableCell>
            </TableRow>
          ))}
        </TableBody>
      </TableRoot>
      <p class="mt-4 text-center text-sm text-body-secondary">Part-time and remote modes typically start every 4–6 weeks.</p>
    </div>
  </section>

  <section class="section bg-canvas">
    <div class="container-main">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <Badge color="warning" size="md" className="mb-4">Key Deadlines</Badge>
        <h2 class="text-3xl font-bold text-body md:text-4xl">Admissions milestones you should not miss</h2>
      </div>

      <ol class="relative mx-auto max-w-3xl border-l border-border pl-8">
        {keyDeadlines.map((d, i) => (
          <li class="relative pb-10 last:pb-0">
            <span class="absolute -left-[42px] flex h-8 w-8 items-center justify-center rounded-full bg-warning text-xs font-bold text-white ring-4 ring-white">{i + 1}</span>
            <Card className="p-5 shadow-sm">
              <CardContent className="px-0 py-0">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between">
                  <div class="text-sm font-bold text-warning">{d.date}</div>
                  <div class="text-base text-body">{d.stage}</div>
                </div>
              </CardContent>
            </Card>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <CTABand
    title="Set yourself a calendar reminder."
    description="Bookmark our Dates & Deadlines page. We update it within 24 hours of any change."
    primaryCta={{ href: '/admissions', label: 'Back to admissions' }}
    secondaryCta={{ href: '/contact', label: 'Get a deadline reminder email' }}
  />
</Layout>
