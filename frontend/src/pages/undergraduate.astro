---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTABand from '../components/CTABand.astro';
import { Link } from '@/components/tailgrids/core/link';
import { Badge } from '@/components/tailgrids/core/badge';
import { Card, CardHeader, CardTitle, CardContent, CardFooter } from '@/components/tailgrids/core/card';
import { buttonStyles } from '@/components/tailgrids/core/button';
import { List } from '@/components/tailgrids/core/list';
import { Separator } from '@/components/tailgrids/core/separator';

const programmes = [
  {
    title: 'Diploma in Information Communication Technology',
    duration: '2 years · TVETA Diploma',
    description: 'Foundational ICT programme covering hardware, networking, software, and a 6-month industrial attachment.',
    href: '/programs/tveta/ict-diploma',
  },
  {
    title: 'Certificate in Business Management',
    duration: '1 year · Certificate',
    description: 'Foundational business skills across entrepreneurship, accounting, marketing, and people management.',
    href: '/programs/business/business-management',
  },
  {
    title: 'Certificate in Digital Marketing',
    duration: '6 months · Certificate',
    description: 'Modern marketing practice including SEO, paid acquisition, content, and analytics with AI tools.',
    href: '/programs/business/digital-marketing',
  },
  {
    title: 'Certificate in Graphic Design',
    duration: '6 months · Certificate',
    description: 'Visual design and branding portfolio built on Figma and the Adobe suite.',
    href: '/programs/tveta/graphics-design',
  },
  {
    title: 'Certificate in Human Resources Practice',
    duration: '6 months · Certificate',
    description: 'HR practitioner track covering recruitment, performance, payroll, and Kenyan labour law.',
    href: '/programs/business/human-resources',
  },
  {
    title: 'TVETA Electrical Installation',
    duration: '1 year · TVETA Certificate',
    description: 'Operative competency training in domestic and commercial wiring with apprenticeship placements.',
    href: '/programs/tveta/electrical-installation',
  },
  {
    title: 'TVETA Plumbing & Pipe Fitting',
    duration: '1 year · TVETA Certificate',
    description: 'Practical plumbing systems training with apprenticeships and on-site practice.',
    href: '/programs/tveta/plumbing-pipe-fitting',
  },
];

const entryRequirements = [
  'KCSE certificate (specific grade requirements per programme, see programme page)',
  'National ID or passport',
  'Successful application to the chosen programme',
];
---

<Layout
  title="Undergraduate | IJLAPS"
  description="IJLAPS undergraduate programmes: diploma and certificate tracks in ICT, business, marketing, HR, and TVETA trades. Entry requirements, durations, and pathways."
  canonicalPath="/undergraduate"
  keywords={['IJLAPS undergraduate', 'TVETA diploma', 'business certificate Kenya', 'ICT diploma Nairobi']}
>
  <Breadcrumbs crumbs={[{ label: 'Home', href: '/' }, { label: 'Academics', href: '/academics' }, { label: 'Undergraduate' }]} />

  <PageHero
    eyebrow="Academics"
    title="Diploma and certificate pathways."
    subtitle="IJLAPS treats undergraduate study as a foundation for either direct career entry or further study. Our diploma and certificate programmes are designed for working adults as well as new KCSE graduates."
  />

  <section class="section bg-surface">
    <div class="container-main">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <Badge color="primary" size="md" className="mb-4">Programmes</Badge>
        <h2 class="text-3xl font-bold text-body md:text-4xl">Diploma and certificate pathways</h2>
        <p class="mt-4 text-lg text-body-secondary">
          Most programmes run between 6 months and 2 years. Diplomas include an industrial attachment component
          with a partner employer.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {programmes.map((p) => (
          <Card className="flex flex-col shadow-sm">
            <CardHeader>
              <CardTitle className="text-xl">{p.title}</CardTitle>
              <p class="mt-2 text-sm font-medium text-primary">{p.duration}</p>
            </CardHeader>
            <CardContent>
              <p class="text-body-secondary">{p.description}</p>
            </CardContent>
            <CardFooter>
              <Link variant="primary" size="sm" href={p.href}>
                Programme details →
              </Link>
            </CardFooter>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <Separator class="my-8" />

  <section class="section bg-canvas">
    <div class="container-main">
      <div class="grid gap-12 lg:grid-cols-2">
        <div>
          <Badge color="primary" size="md" className="mb-4">Entry requirements</Badge>
          <h2 class="text-3xl font-bold text-body">What you'll need to apply</h2>
          <p class="mt-4 text-body-secondary">
            The undergraduate-track entry requirements are designed to be transparent and pre-published. Some
            programmes request a placement assessment or interview, see the programme page.
          </p>
          <List class="mt-6 max-w-none" hideDividers>
            {entryRequirements.map((r) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 inline-flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-primary text-xs font-bold text-white">✓</span>
                <span class="text-body-secondary">{r}</span>
              </li>
            ))}
          </List>
        </div>
        <div class="rounded-2xl bg-primary p-8 text-white md:p-12">
          <h3 class="text-2xl font-bold">Plan your entry</h3>
          <p class="mt-3 text-white/85">
            Some applicants join us after a Bachelor programme elsewhere. If your transcript isn't from a system
            we recognise, the admissions team will assess your case individually.
          </p>
          <a href="/contact" class={buttonStyles({ variant: 'primary', appearance: 'outline', size: 'md', class: 'mt-6 inline-flex' })}>
            Talk to admissions
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTABand
    title="Apply to an undergraduate programme"
    description="Three intakes a year, January, May, and September."
    primaryCta={{ href: '/how-to-apply', label: 'How to apply' }}
    secondaryCta={{ href: '/tuition-fees', label: 'See tuition & fees' }}
  />
</Layout>
