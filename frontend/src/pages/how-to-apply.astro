---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTABand from '../components/CTABand.astro';
import { Badge } from '@/components/tailgrids/core/badge';
import { Card, CardHeader, CardTitle, CardContent } from '@/components/tailgrids/core/card';
import { Alert, AlertIndicator, AlertContent, AlertTitle, AlertDescription } from '@/components/tailgrids/core/alert';
import { buttonStyles } from '@/components/tailgrids/core/button';
import { Separator } from '@/components/tailgrids/core/separator';

const steps = [
  {
    step: '01',
    title: 'Choose your programme',
    description: 'Browse our language, technology, business, or TVETA programmes. Each programme page lists prerequisites and modes of study so you can confirm a match before applying.',
    action: 'Browse /languages, /programs/tech, /programs/business, /programs/tveta',
  },
  {
    step: '02',
    title: 'Complete the application form',
    description: 'Submit a personal and academic profile through our admissions form. You can save and resume the form. Almost all our applications are submitted online.',
    action: 'Application fee: KES 2,500 (non-refundable)',
  },
  {
    step: '03',
    title: 'Submit the required documents',
    description: 'Upload scans of your academic certificates, identification, and passport-size photographs. Some programmes request a short assessment or interview, see the programme detail page.',
    action: 'Documents checklist below',
  },
  {
    step: '04',
    title: 'Receive your admission letter',
    description: 'Once your application is reviewed, you receive a formal admission letter with your cohort start date, fee schedule, and any orientation requirements.',
    action: 'Decision turnaround: 5–10 working days',
  },
];

const documents = [
  'Completed application form (online submission)',
  'Copy of KCSE certificate (or equivalent national exam)',
  'Copies of academic transcripts for tertiary study, where applicable',
  'National ID or passport copy (non-Kenyan applicants)',
  'Two recent passport-size photographs',
  'Application fee receipt (KES 2,500)',
  'Personal statement (500 words for graduate applicants)',
  'CV (for technology and business bootcamps)',
];

const afterAcceptance = [
  { label: 'Joining fee payment', note: 'Top-up to confirm your place, see Tuition & Fees.' },
  { label: 'Orientation week', note: 'All programmes have a week-long orientation before formal classes begin.' },
  { label: 'Registration confirmation', note: 'You will receive your cohort schedule, course materials, and login credentials for the student portal.' },
];
---

<Layout
  title="How to Apply | IJLAPS"
  description="Step-by-step application guide for IJLAPS programmes. Requirements, documents, fees, and what to expect after acceptance."
  canonicalPath="/how-to-apply"
  keywords={['IJLAPS application', 'how to apply IJLAPS', 'Kenya education application', 'TVETA application process']}
>
  <Breadcrumbs crumbs={[{ label: 'Home', href: '/' }, { label: 'Admissions', href: '/admissions' }, { label: 'How to Apply' }]} />

  <PageHero
    eyebrow="Admissions"
    title="Your application, step by step."
    subtitle="Applying to IJLAPS is intentionally straightforward. The four steps below apply to every language, technology, business, and TVETA programme."
  />

  <section class="section bg-surface">
    <div class="container-main">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <Badge color="primary" size="md" className="mb-4">Process</Badge>
        <h2 class="text-3xl font-bold text-body md:text-4xl">The four steps</h2>
        <p class="mt-4 text-lg text-body-secondary">
          The full process takes 5–10 working days from submission to decision. We notify you by email when your
          admission letter is ready in the student portal.
        </p>
      </div>

      <ol class="space-y-6">
        {steps.map((s) => (
          <li class="grid gap-6 rounded-2xl border border-border bg-surface p-6 shadow-sm md:grid-cols-[80px_1fr] md:items-start md:p-8">
            <span class="flex h-16 w-16 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 text-2xl font-extrabold text-primary">
              {s.step}
            </span>
            <div>
              <h3 class="text-2xl font-bold text-body">{s.title}</h3>
              <p class="mt-3 text-body-secondary">{s.description}</p>
              <p class="mt-3 text-sm font-medium text-primary">{s.action}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <Separator class="my-8" />

  <section class="section bg-canvas">
    <div class="container-main">
      <div class="grid gap-12 lg:grid-cols-[1fr_1.2fr]">
        <div>
          <Badge color="primary" size="md" className="mb-4">Documents</Badge>
          <h2 class="text-3xl font-bold text-body">What you'll need to submit</h2>
          <p class="mt-4 text-lg text-body-secondary">
            Have the following ready before you start the application form. You can upload scanned PDFs or sharp
            photos, both are accepted.
          </p>
        </div>
        <ul class="grid gap-3 sm:grid-cols-2">
          {documents.map((doc, i) => (
            <li class="flex items-start gap-3 rounded-lg border border-border bg-surface p-3 text-sm text-body-secondary">
              <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-primary text-xs font-bold text-white">{i + 1}</span>
              <span>{doc}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <Separator class="my-8" />

  <section class="section bg-surface">
    <div class="container-main">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <Badge color="primary" size="md" className="mb-4">After Acceptance</Badge>
        <h2 class="text-3xl font-bold text-body md:text-4xl">What happens next?</h2>
        <p class="mt-4 text-lg text-body-secondary">
          Once your admission letter is ready, three steps happen before you start classes.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {afterAcceptance.map((a, i) => (
          <Card className="shadow-sm">
            <CardHeader>
              <Badge color="primary" size="sm">Step {i + 1}</Badge>
              <CardTitle className="mt-3">{a.label}</CardTitle>
            </CardHeader>
            <CardContent>
              <p class="text-sm text-body-secondary">{a.note}</p>
            </CardContent>
          </Card>
        ))}
      </div>

      <Alert status="info" className="mt-12">
        <AlertIndicator />
        <AlertContent>
          <AlertTitle>Ready to begin?</AlertTitle>
          <AlertDescription>
            <p>You can save and resume your application. The online portal walks you through the same checklist as above, with file-upload guidance.</p>
            <div class="mt-4 flex flex-col items-center justify-center gap-3 sm:flex-row">
              <a href="/contact" class={buttonStyles({ variant: 'primary', appearance: 'fill', size: 'lg' })}>
                Start application
              </a>
              <a href="/tuition-fees" class={buttonStyles({ variant: 'primary', appearance: 'outline', size: 'lg' })}>
                See tuition & fees
              </a>
            </div>
          </AlertDescription>
        </AlertContent>
      </Alert>
    </div>
  </section>

  <CTABand
    eyebrow="Help"
    title="Need support during your application?"
    description="Our admissions team works with prospective students Monday to Friday, 9am to 4pm EAT."
    primaryCta={{ href: '/contact', label: 'Contact admissions' }}
    secondaryCta={{ href: '/faq', label: 'Read FAQs' }}
  />
</Layout>
