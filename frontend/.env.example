# Frappe backend URL used by the Astro frontend at build/runtime.
# Example: http://lingua.localhost or http://localhost:8080
PUBLIC_FRAPPE_URL=http://your-site.localhost
# Lead source label recorded for newsletter sign-ups (forwarded to the existing
# Lead DocType via createSubscriber in lib/api.ts). Default: 'Newsletter'.
PUBLIC_NEWSLETTER_SOURCE=Newsletter

# Pexels API key, used to fetch contextual public-domain images for hero, instructor, blog,
# and programme tiles. Get one at https://www.pexels.com/api/.
PEXELS_API_KEY=your_pexels_api_key
